# ---------------------------------------------------------------------------
# Model provider — OpenAI-compatible surface (works for ollama, Ollama Cloud, OpenAI)
# ---------------------------------------------------------------------------
# Local ollama (free path):
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
MODEL=qwen3.5:2b

# Ollama Cloud (larger, more reliable tool-calling for the live demo):
# OPENAI_BASE_URL=https://ollama.com/v1
# OPENAI_API_KEY=<your-ollama-cloud-key>
# MODEL=qwen2.5:72b

# OpenAI (drop-in alternative):
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# MODEL=gpt-4o-mini

# Anthropic (Claude) — OpenAI-compatible endpoint. This is a compatibility shim,
# not Anthropic's native API; fine for a demo, switch to langchain-anthropic /
# the anthropic SDK for production. See workshop/guide/01-setup-and-data.md.
# OPENAI_BASE_URL=https://api.anthropic.com/v1/
# OPENAI_API_KEY=sk-ant-...
# MODEL=claude-opus-4-8

# Google (Gemini) — OpenAI-compatible endpoint (also a shim):
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# OPENAI_API_KEY=<your-gemini-key>
# MODEL=gemini-2.5-pro

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
METEO_DB_PATH=data/meteobeguda.sqlite

# ---------------------------------------------------------------------------
# Langfuse (self-hosted via docker compose; keys are created in the Langfuse UI)
# ---------------------------------------------------------------------------
# These match the LANGFUSE_INIT_* keys auto-provisioned by docker-compose.yml.
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-meteo-workshop-0000000000000000
LANGFUSE_SECRET_KEY=sk-lf-meteo-workshop-0000000000000000
